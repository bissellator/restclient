{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "REST Client",
  "version": "1.0.0",
  "identifier": "com.restclient.app",
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "node server.js",
    "devUrl": "http://localhost:8010",
    "frontendDist": "../public"
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": "all",
    "resources": [
      "../server.js",
      "../public/**/*",
      "../package.json"
    ]
  },
  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "fullscreen": false,
        "height": 800,
        "resizable": true,
        "title": "REST Client",
        "width": 1200,
        "minWidth": 800,
        "minHeight": 600,
        "url": "http://localhost:8010"
      }
    ]
  }
}
