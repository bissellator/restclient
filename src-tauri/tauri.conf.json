{
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "node server.js",
    "devPath": "http://localhost:8010",
    "distDir": "../public"
  },
  "package": {
    "productName": "REST Client",
    "version": "1.0.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "open": true
      }
    },
    "bundle": {
      "active": true,
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "identifier": "com.restclient.app",
      "targets": "all",
      "resources": [
        "../server.js",
        "../public/**/*",
        "../package.json"
      ]
    },
    "security": {
      "csp": null
    },
    "windows": [
      {
        "fullscreen": false,
        "height": 800,
        "resizable": true,
        "title": "REST Client",
        "width": 1200,
        "minWidth": 800,
        "minHeight": 600,
        "url": "http://localhost:8010"
      }
    ]
  }
}
